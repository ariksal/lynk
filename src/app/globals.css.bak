@import "tailwindcss";

/* ==========================================================================
   LYNK design tokens — the real brand, mirrored from the LYNK mobile app
   (constants/colors.ts). Ocean-blue primary signals connection; rose accent
   is used sparingly for unread / attention. Cool, calm, human.
   ========================================================================== */
:root {
  --background: #f0f4f7;       /* cool light gray-blue */
  --surface: #ffffff;
  --foreground: #1a1a2e;       /* deep navy ink */
  --muted: #6b7280;            /* textSecondary */
  --text-muted: #9ca3af;       /* textMuted */
  --border: #e5ebf0;
  --primary: #1f87ad;          /* ocean blue — "connection" */
  --primary-hover: #186e8e;    /* primaryDark */
  --primary-soft: #e8f4f8;     /* primaryLight */
  --accent: #cb2a57;           /* rose — unread / attention */
  --accent-soft: #fdeef3;      /* accentLight */
  --success: #22c55e;
  --radius: 1rem;
}

@theme inline {
  --color-background: var(--background);
  --color-surface: var(--surface);
  --color-foreground: var(--foreground);
  --color-muted: var(--muted);
  --color-text-muted: var(--text-muted);
  --color-border: var(--border);
  --color-primary: var(--primary);
  --color-primary-hover: var(--primary-hover);
  --color-primary-soft: var(--primary-soft);
  --color-accent: var(--accent);
  --color-accent-soft: var(--accent-soft);
  --color-success: var(--success);
  --font-sans: var(--font-dm-sans);
  --font-display: var(--font-raleway);
  --radius-app: var(--radius);
}

html {
  scroll-behavior: smooth;
  /* Avoid the grey flash on tap; we provide our own press feedback. */
  -webkit-tap-highlight-color: transparent;
}

body {
  background: var(--background);
  color: var(--foreground);
  font-family: var(--font-dm-sans), system-ui, sans-serif;
  -webkit-font-smoothing: antialiased;
  /* Stop scroll chaining to the page behind the phone column. */
  overscroll-behavior-y: contain;
}

/* Visible keyboard focus on every interactive element. */
:where(a, button, input, textarea, select, [tabindex]):focus-visible {
  outline: none;
  box-shadow: 0 0 0 3px var(--primary-soft), 0 0 0 4.5px var(--primary);
  border-radius: 0.6rem;
}

/* Instant tactile feedback: a subtle press on tap/click. */
.press {
  transition: transform 0.12s ease, background-color 0.15s ease, opacity 0.15s ease;
}
.press:active {
  transform: scale(0.96);
}

/* Skeleton shimmer for loading states. */
.skeleton {
  background: linear-gradient(
    100deg,
    var(--border) 30%,
    #f3f6f9 50%,
    var(--border) 70%
  );
  background-size: 200% 100%;
  animation: lynk-shimmer 1.3s ease-in-out infinite;
  border-radius: 0.6rem;
}
@keyframes lynk-shimmer {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

/* Gentle entrance for routed content. */
@keyframes lynk-fade-up {
  from { opacity: 0; transform: translateY(6px); }
  to { opacity: 1; transform: none; }
}
.animate-in {
  animation: lynk-fade-up 0.28s ease both;
}

/* Honor users who prefer less motion. */
@media (prefers-reduced-motion: reduce) {
  html { scroll-behavior: auto; }
  *,
  *::before,
  *::after {
    animation-duration: 0.001ms !important;
    animation-iteration-count: 1 !important;
    transition-duration: 0.001ms !important;
  }
}

/* Titles use Raleway, matching the mobile app's display type. */
.font-display {
  font-family: var(--font-raleway), system-ui, sans-serif;
}

/* Reusable building blocks */
.lynk-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius);
}
.lynk-tag {
  display: inline-flex;
  align-items: center;
  font-size: 0.78rem;
  padding: 0.15rem 0.6rem;
  border-radius: 999px;
  background: var(--primary-soft);
  color: var(--primary-hover);
}
.lynk-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 0.5rem;
  font-weight: 600;
  border-radius: 999px;
  background: var(--primary);
  color: #fff;
  padding: 0.6rem 1.25rem;
  transition: background 0.15s ease;
}
.lynk-btn:hover { background: var(--primary-hover); }
.lynk-btn:active { transform: scale(0.97); }
.lynk-btn-ghost {
  background: transparent;
  color: var(--foreground);
  border: 1px solid var(--border);
}
.lynk-btn-ghost:hover { background: var(--primary-soft); color: var(--primary-hover); }
.lynk-input {
  width: 100%;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 0.7rem;
  padding: 0.65rem 0.85rem;
  outline: none;
}
.lynk-input:focus { border-color: var(--primary); box-shadow: 0 0 0 3px var(--primary-soft); }
